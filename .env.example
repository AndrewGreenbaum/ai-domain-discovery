# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/aidomains

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# External APIs
CT_LOG_API=https://crt.sh/json

# Discovery Settings
DISCOVERY_SCHEDULE=0 9,14,20 * * *
MAX_CONCURRENT_VALIDATIONS=10
DOMAIN_TIMEOUT=2

# Alert Settings (Optional)
ALERT_EMAIL=

# Timezone
TZ=UTC
